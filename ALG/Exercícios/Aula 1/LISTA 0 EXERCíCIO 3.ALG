Algoritmo "Lista 1 Exercício 3"
// Disciplina  : Algoritmos
// Professor   : Douglas Dutra
// Descriçăo   : Antecessor e Sucessor
// Autor(a)    : Pedro Henrique dos Santos
// Data atual  : 04/03/2026
Var
// Seçăo de Declaraçőes das variáveis
   n, x : real
Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
   escreval("Insira um número:")
   leia(n)
   x <- n-1
   escreval("Antecessor: ", x)
   x <- n+1
   escreval("Sucessor: ", x)
Fimalgoritmo