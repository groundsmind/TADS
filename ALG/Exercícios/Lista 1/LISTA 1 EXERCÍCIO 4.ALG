Algoritmo "LISTA 1 EXERCÍCIO 4"
Var
// Seçăo de Declaraçőes das variáveis 
   vi, a, t, vf : real

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 

   escreval("Insira velocidade inicial:")
   leia(vi)
   escreval("Insira aceleraçăo:")
   leia(a)
   escreval("Insira tempo:")
   leia(t)
   vf <- vi + (a*t)
   escreval("Velocidade final:", vf)
Fimalgoritmo