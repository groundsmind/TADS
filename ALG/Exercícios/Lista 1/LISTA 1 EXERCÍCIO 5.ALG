Algoritmo "LISTA 1 EXERCÍCIO 5"
Var
// Seçăo de Declaraçőes das variáveis 
   r, a, v : real

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
   escreval("Insira raio:")
   leia(r)
   escreval("Insira altura:")
   leia(a)
   v <- pi*(r^2)*a
   escreval("Volume:", v)
Fimalgoritmo